---
import FaqCategory from '../components/FaqCategory.astro';
import FaqItem from '../components/FaqItem.astro';
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

const rawEntries = await getCollection('preguntas-frecuentes');
const categories = rawEntries.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Preguntas Frecuentes - Universidad de Pamplona">
  <PageHero subtitle="Encuentra respuestas rápidas o pregunta al chatbot si no ves tu duda aquí.">
    <Fragment slot="title">
      Preguntas Frecuentes<br />
      Sobre el Proceso de Graduación
    </Fragment>
  </PageHero>

  <section class="faq-section">
    <div class="container">
      {
        categories.map((category) => (
          <FaqCategory
            title={category.data.title}
            imageSrc={category.data.imageSrc}
            imageAlt={category.data.imageAlt}
            descriptions={category.data.descriptions}
          >
            {
              category.data.preguntas.map((pregunta) => {
                const answerHtml = marked.parse(pregunta.answer, { async: false }) as string;
                return (
                  <FaqItem question={pregunta.question}>
                    <Fragment set:html={answerHtml} />
                  </FaqItem>
                );
              })
            }
          </FaqCategory>
        ))
      }
    </div>
  </section>
</Layout>

<script is:inline>
  if (!window.__faqState) {
    window.__faqState = {
      bound: false,
    };
  }

  function collapseFaqItem(item) {
    if (!(item instanceof HTMLElement)) {
      return;
    }

    item.classList.remove('active');

    const answer = item.querySelector('.faq-answer');
    const icon = item.querySelector('.faq-icon');

    if (answer instanceof HTMLElement) {
      answer.style.maxHeight = '0';
    }

    if (icon instanceof HTMLElement || icon instanceof SVGElement) {
      icon.style.transform = 'rotate(0deg)';
    }
  }

  function resetFaqAnswers() {
    document.querySelectorAll('.faq-item').forEach((item) => {
      collapseFaqItem(item);
    });
  }

  function setupFaqBehavior() {
    const state = window.__faqState;
    if (state.bound) {
      return;
    }

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }

      const button = target.closest('[data-faq-toggle]');
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const faqItem = button.closest('.faq-item');
      const category = button.closest('.faq-category');
      const answer = faqItem?.querySelector('.faq-answer');
      const icon = button.querySelector('.faq-icon');

      if (
        !(faqItem instanceof HTMLElement) ||
        !(category instanceof HTMLElement) ||
        !(answer instanceof HTMLElement) ||
        (!(icon instanceof HTMLElement) && !(icon instanceof SVGElement))
      ) {
        return;
      }

      const isOpen = faqItem.classList.contains('active');

      category.querySelectorAll('.faq-item.active').forEach((item) => {
        collapseFaqItem(item);
      });

      if (!isOpen) {
        faqItem.classList.add('active');
        answer.style.maxHeight = `${answer.scrollHeight}px`;
        icon.style.transform = 'rotate(180deg)';
      }
    });

    state.bound = true;
  }

  function initFaq() {
    setupFaqBehavior();
    resetFaqAnswers();
  }

  if (!window.__faqLoadBound) {
    document.addEventListener('astro:page-load', initFaq);
    window.__faqLoadBound = true;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFaq, { once: true });
  } else {
    initFaq();
  }
</script>

<style is:global>
  @view-transition {
    navigation: auto;
  }

  .faq-section {
    padding: 40px 0 60px;
    background: #f8f9fa;
  }

  .faq-category {
    background: white;
    border-radius: 12px;
    margin-bottom: 40px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .category-header {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 30px;
    padding: 30px;
    align-items: center;
  }

  .category-image {
    position: relative;
  }

  .category-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 8px;
  }

  .category-title {
    font-size: 2rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 15px;
  }

  .category-description {
    font-size: 1rem;
    color: #666;
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .category-description:last-child {
    margin-bottom: 0;
  }

  .faq-list {
    border-top: 1px solid #f0f0f0;
  }

  .faq-item {
    border-bottom: 1px solid #f0f0f0;
  }

  .faq-question {
    width: 100%;
    padding: 20px 30px;
    background: none;
    border: none;
    text-align: left;
    font-size: 1rem;
    font-weight: 500;
    color: #333;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
  }

  .faq-question:hover {
    background-color: #f8f9fa;
    color: #d32f2f;
  }

  .faq-question span {
    flex: 1;
    text-align: left;
  }

  .faq-icon {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 15px;
  }

  .faq-answer {
    padding: 0 30px;
    max-height: 0;
    overflow: hidden;
    transition: all 0.3s ease;
    background-color: #fafafa;
  }

  .faq-answer :global(p),
  .faq-answer :global(ul) {
    padding: 20px 0 24px;
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #555;
  }

  .faq-answer :global(ul) {
    list-style: none;
    padding-left: 0;
  }

  .faq-answer :global(li) {
    padding: 5px 0;
    position: relative;
    padding-left: 20px;
  }

  .faq-answer :global(li::before) {
    content: '•';
    color: #d32f2f;
    font-weight: bold;
    position: absolute;
    left: 0;
  }

  .faq-answer :global(a) {
    color: #d32f2f;
    text-decoration: underline;
    transition: opacity 0.3s ease;
  }

  .faq-answer :global(a:hover) {
    opacity: 0.8;
  }

  .faq-item.active .faq-question {
    background-color: #f8f9fa;
    color: #d32f2f;
  }

  @media (max-width: 768px) {
    .category-header {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 20px;
      text-align: center;
    }

    .category-title {
      font-size: 1.5rem;
    }

    .faq-question {
      padding: 14px 16px;
      font-size: 0.95rem;
      gap: 10px;
      line-height: 1.4;
    }

    .faq-answer {
      padding: 0 20px;
    }

    .faq-answer :global(p),
    .faq-answer :global(ul) {
      padding: 16px 0 20px;
      font-size: 0.9rem;
    }

    .faq-icon {
      width: 18px;
      height: 18px;
      margin-left: 10px;
    }
  }

  @media (max-width: 480px) {
    .faq-section {
      padding: 30px 0 40px;
    }

    .category-header {
      padding: 14px;
      gap: 14px;
    }

    .category-img {
      height: 180px;
    }

    .category-title {
      font-size: 1.2rem;
      margin-bottom: 10px;
    }

    .category-description {
      font-size: 0.88rem;
      line-height: 1.45;
    }

    .faq-question {
      padding: 12px 14px;
      font-size: 0.88rem;
    }

    .faq-answer {
      padding: 0 14px;
    }

    .faq-answer :global(p),
    .faq-answer :global(ul) {
      padding: 14px 0 18px;
      font-size: 0.86rem;
      line-height: 1.5;
    }
  }

  @media (max-width: 360px) {
    .faq-section {
      padding: 24px 0 32px;
    }

    .faq-category {
      border-radius: 10px;
      margin-bottom: 24px;
    }

    .category-header {
      padding: 12px;
    }

    .category-img {
      height: 155px;
      border-radius: 6px;
    }

    .category-title {
      font-size: 1.05rem;
    }

    .category-description {
      font-size: 0.8rem;
    }

    .faq-question {
      padding: 11px 12px;
      font-size: 0.82rem;
    }

    .faq-icon {
      width: 16px;
      height: 16px;
      margin-left: 8px;
    }

    .faq-answer {
      padding: 0 12px;
    }

    .faq-answer :global(p),
    .faq-answer :global(ul) {
      padding: 12px 0 16px;
      font-size: 0.8rem;
    }
  }
</style>
