---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const rawEntries = await getCollection('contacto-recursos');
const secciones = rawEntries.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  secciones.map((entry) => render(entry)),
);
---

<Layout title="Contactos y Documentos - Universidad de Pamplona">
<main class="main-content">
  <div class="container">
    {
      secciones.map((seccion, i) => {
        const { Content } = rendered[i]!;
        return (
          <section class="section">
            <h2 class="section-title">{seccion.data.title}</h2>
            <div class="section-body">
              <Content />
            </div>
          </section>
        );
      })
    }
  </div>
</main>
</Layout>

<style>
  .main-content {
    padding: 100px 0 50px;
    background: #f8f9fa;
    min-height: 100vh;
  }

  .section {
    background: white;
    border-radius: 12px;
    padding: 40px;
    margin-bottom: 30px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    color: #2c3e50;
    margin-bottom: 30px;
    text-align: center;
    border-bottom: 3px solid #d32f2f;
    padding-bottom: 15px;
  }

  .section-body :global(p) {
    margin-bottom: 12px;
    line-height: 1.7;
    color: #555;
    font-size: 1rem;
  }

  .section-body :global(h2) {
    font-size: 1.3rem;
    font-weight: 600;
    color: #2c3e50;
    margin: 24px 0 16px;
  }

  .section-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: #d32f2f;
    margin: 20px 0 10px;
  }

  .section-body :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-body :global(li) {
    padding: 12px 16px;
    background: #f8f9fa;
    border-radius: 8px;
    line-height: 1.5;
    color: #555;
    font-size: 1rem;
  }

  .section-body :global(a) {
    color: #1976d2;
    text-decoration: none;
    font-weight: 500;
  }

  .section-body :global(a:hover) {
    text-decoration: underline;
  }

  .section-body :global(strong) {
    color: #333;
    font-weight: 600;
  }

  .section-body :global(em) {
    color: #999;
    font-style: italic;
  }

  .section-body :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #2c3e50;
    margin: 24px 0 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid #eee;
  }

  @media (max-width: 768px) {
    .main-content {
      padding: 28px 0 26px;
    }

    .section {
      padding: 20px 16px;
      margin-bottom: 16px;
      border-radius: 10px;
    }

    .section-title {
      font-size: 1.35rem;
      margin-bottom: 18px;
      padding-bottom: 10px;
    }

    .section-body :global(li) {
      padding: 10px 12px;
      font-size: 0.92rem;
    }

    .section-body :global(p),
    .section-body :global(a) {
      font-size: 0.92rem;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 16px 14px;
    }

    .section-title {
      font-size: 1.18rem;
    }

    .section-body :global(li) {
      padding: 8px 10px;
      font-size: 0.84rem;
    }

    .section-body :global(p),
    .section-body :global(a) {
      font-size: 0.84rem;
    }
  }

  @media (max-width: 360px) {
    .main-content {
      padding: 22px 0;
    }

    .section {
      padding: 14px 12px;
    }

    .section-title {
      font-size: 1.05rem;
    }

    .section-body :global(li) {
      padding: 6px 8px;
      font-size: 0.78rem;
    }

    .section-body :global(p),
    .section-body :global(a) {
      font-size: 0.78rem;
    }
  }
</style>
