---
import Layout from '../layouts/Layout.astro';
import GraduationTabContent from '../components/GraduationTabContent.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection, render } from 'astro:content';

const rawSecciones = await getCollection('proceso-graduacion');
const secciones = rawSecciones.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  secciones.map((entry) => render(entry)),
);
---

<Layout title="Proceso de Graduación - Universidad de Pamplona">
  <PageHero subtitle="Todo lo que necesitas saber para culminar tus estudios.">
    <Fragment slot="title">
      "Proceso de Graduación en<br />
      Ingeniería de Sistemas"
    </Fragment>
  </PageHero>

  <!-- Content Section -->
  <section class="content-section">
    <div class="container">
      
      <!-- Simple Tabs Navigation -->
      <div class="simple-tabs">
        {
          secciones.map((seccion, i) => (
            <button
              class={`simple-tab${i === 0 ? ' active' : ''}`}
              data-tab={seccion.id}
              type="button"
            >
              {seccion.data.title}
            </button>
          ))
        }
      </div>

      <!-- Tab Content -->
      <div class="tab-content-wrapper">
        {
          secciones.map((seccion, i) => {
            const { Content } = rendered[i]!;
            return (
              <GraduationTabContent
                id={seccion.id}
                title={seccion.data.title}
                imageSrc={seccion.data.imageSrc}
                imageAlt={seccion.data.imageAlt}
                active={i === 0}
              >
                <Content />
              </GraduationTabContent>
            );
          })
        }
      </div>
    </div>
  </section>

</Layout>

<script is:inline>
  if (!window.__smoothTabsState) {
    window.__smoothTabsState = {
      isTransitioning: false,
      bound: false,
    };
  }

  function initSmoothTabs() {
    const state = window.__smoothTabsState;
    const tabButtons = document.querySelectorAll('.simple-tab');
    const tabContents = document.querySelectorAll('.tab-content');

    if (!tabButtons.length || !tabContents.length) {
      return;
    }

    tabButtons.forEach((button) => {
      const isActive = button.classList.contains('active');
      button.setAttribute('aria-selected', String(isActive));
      button.setAttribute('role', 'tab');
    });

    if (!state.bound) {
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) {
          return;
        }

        const button = target.closest('.simple-tab');
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        event.preventDefault();

        if (state.isTransitioning) {
          return;
        }

        const targetTab = button.getAttribute('data-tab');
        const currentActive = document.querySelector('.tab-content.active');
        const targetContent = targetTab ? document.getElementById(targetTab) : null;

        if (!targetContent || targetContent === currentActive || !(currentActive instanceof HTMLElement)) {
          return;
        }

        state.isTransitioning = true;

        document.querySelectorAll('.simple-tab').forEach((tabButton) => {
          tabButton.classList.remove('active');
          tabButton.setAttribute('aria-selected', 'false');
        });

        button.classList.add('active');
        button.setAttribute('aria-selected', 'true');

        currentActive.style.opacity = '0';
        currentActive.style.transform = 'translateY(20px)';

        window.setTimeout(() => {
          document.querySelectorAll('.tab-content').forEach((content) => {
            content.classList.remove('active');
          });

          targetContent.classList.add('active');
          targetContent.style.opacity = '0';
          targetContent.style.transform = 'translateY(20px)';

          requestAnimationFrame(() => {
            targetContent.style.opacity = '1';
            targetContent.style.transform = 'translateY(0)';

            window.setTimeout(() => {
              state.isTransitioning = false;
            }, 300);
          });
        }, 150);
      });

      state.bound = true;
    }
  }

  if (!window.__smoothTabsLoadBound) {
    document.addEventListener('astro:page-load', initSmoothTabs);
    window.__smoothTabsLoadBound = true;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSmoothTabs, { once: true });
  } else {
    initSmoothTabs();
  }
</script>

<style>
  /* Content Section */
  .content-section {
    padding: 40px 0 60px;
    background: #ffffff;
    background: linear-gradient(0deg,rgba(255, 255, 255, 1) 0%, rgba(230, 230, 230, 1) 100%);
  }

  /* Simple Tabs */
  .simple-tabs {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid #e0e0e0;
  }

  .simple-tab {
    background: none;
    border: none;
    font-size: 1rem;
    font-weight: 500;
    color: #666;
    cursor: pointer;
    padding: 8px 0;
    transition: all 0.3s ease;
    position: relative;
  }

  .simple-tab:hover {
    color: #d32f2f;
  }

  .simple-tab.active {
    color: #d32f2f;
    font-weight: 600;
  }

  .simple-tab.active::after {
    content: '';
    position: absolute;
    bottom: -20px;
    left: 0;
    right: 0;
    height: 2px;
    background: #d32f2f;
    transition: bottom 0.2s, height 0.2s;
  }

  /* Tab Content */
  .tab-content-wrapper {
    position: relative;
    min-height: 600px; /* Prevenir saltos de layout */
  }

  /* Smooth transitions for view transitions */
  @view-transition {
    navigation: auto;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .simple-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      text-align: left;
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 24px;
    }

    .simple-tab {
      background: #fff;
      border: 1px solid #e6e6e6;
      border-radius: 10px;
      padding: 12px 10px;
      font-size: 0.9rem;
      line-height: 1.35;
      min-height: 72px;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .simple-tab.active {
      border-color: #d32f2f;
      background: #fff8f8;
      box-shadow: 0 2px 8px rgba(211, 47, 47, 0.12);
    }

    .simple-tab.active::after {
      display: none;
    }

    .tab-content-wrapper {
      min-height: auto;
    }
  }

  @media (max-width: 480px) {
    .content-section {
      padding: 30px 0 40px;
    }

    .simple-tabs {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-bottom: 20px;
    }

    .simple-tab {
      min-height: 50px;
      font-size: 0.88rem;
      padding: 10px;
    }
  }

  @media (max-width: 360px) {
    .content-section {
      padding: 24px 0 34px;
    }

    .simple-tab {
      font-size: 0.84rem;
      min-height: 46px;
    }
  }
</style>
