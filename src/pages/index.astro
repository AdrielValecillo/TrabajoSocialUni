---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Universidad de Pamplona - Orientación para Graduación">
  <section class="hero-section">
    <div class="hero-background">
      <div class="floating-elements">
        <div class="floating-element" style="--delay: 0s; --duration: 6s;"></div>
        <div class="floating-element" style="--delay: 2s; --duration: 8s;"></div>
        <div class="floating-element" style="--delay: 4s; --duration: 7s;"></div>
        <div class="floating-element" style="--delay: 1s; --duration: 9s;"></div>
      </div>
    </div>
    
    <div class="container">
      <div class="hero-content">
        <!-- Left Content -->
        <div class="hero-text" data-aos="fade-right">
          <div class="hero-badge">
            <span class="badge-icon">🎓</span>
            <span>Sistema de Graduación Inteligente</span>
          </div>
          
          <h1 class="hero-title">
            <span class="title-line">Orientación</span>
            <span class="title-line highlight">Automatizada</span>
            <span class="title-line">para tu Graduación</span>
          </h1>
          
          <p class="hero-description">
            Diseñado por el programa de <strong>Ingeniería de Sistemas</strong> de la Universidad de Pamplona. 
            Tu asistente inteligente para navegar todos los requisitos, trámites y procesos de graduación 
            con información oficial y actualizada.
          </p>
          
          <div class="hero-features">
            <div class="feature-item" data-aos="fade-up" data-aos-delay="200">
              <div class="feature-icon">📋</div>
              <span>Requisitos Actualizados</span>
            </div>
            <div class="feature-item" data-aos="fade-up" data-aos-delay="300">
              <div class="feature-icon">⚡</div>
              <span>Respuestas Instantáneas</span>
            </div>
            <div class="feature-item" data-aos="fade-up" data-aos-delay="400">
              <div class="feature-icon">🎯</div>
              <span>Información Oficial</span>
            </div>
          </div>

          <div class="hero-actions" data-aos="fade-up" data-aos-delay="500">
            <a href="/proceso-graduacion">
              <button class="cta-button primary">
                <span class="button-content">
                  <svg class="button-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
                  </svg>
                  Explorar Procesos
                </span>
                <div class="button-glow"></div>
              </button>
            </a>

          </div>
        </div>
        
        <!-- Right Content - Interactive Image -->
        <div class="hero-visual" data-aos="fade-left">
          <div class="image-container">
            <div class="image-glow"></div>
            <img 
              src="/proceso/1.jpg" 
              alt="Estudiantes graduándose" 
              class="hero-image"
            />
          </div>
        </div>
      </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="scroll-indicator" data-aos="fade-up" data-aos-delay="800">
      <div class="scroll-text">Descubre más</div>
      <div class="scroll-arrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="7,13 12,18 17,13"></polyline>
          <polyline points="7,6 12,11 17,6"></polyline>
        </svg>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features-section">
    <div class="container">
      <div class="section-header" data-aos="fade-up">
        <h2 class="section-title">¿Por qué elegir nuestro sistema?</h2>
        <p class="section-subtitle">Una experiencia diseñada para tu éxito académico</p>
      </div>
      
      <div class="features-grid">
        <div class="feature-card" data-aos="fade-up" data-aos-delay="100">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-4m-4-4v8m0-8l3 3m-3-3L9 8"/>
            </svg>
          </div>
          <h3>Información Centralizada</h3>
          <p>Todos los requisitos, formatos y procedimientos en un solo lugar, siempre actualizados.</p>
        </div>
        
        <div class="feature-card" data-aos="fade-up" data-aos-delay="200">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12,6 12,12 16,14"></polyline>
            </svg>
          </div>
          <h3>Disponible 24/7</h3>
          <p>Accede a la información que necesitas en cualquier momento, desde cualquier dispositivo.</p>
        </div>
        
        <div class="feature-card" data-aos="fade-up" data-aos-delay="300">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
            </svg>
          </div>
          <h3>Seguimiento Personalizado</h3>
          <p>Recibe orientación específica según tu modalidad de grado y progreso académico.</p>
        </div>
      </div>
    </div>
  </section>


</Layout>

<script is:inline>
  if (!window.__homeAnimationsState) {
    window.__homeAnimationsState = {
      observer: null,
      scrollHandler: null,
    };
  }

  function initializeAnimations() {
    const state = window.__homeAnimationsState;
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px',
    };

    if (state.observer) {
      state.observer.disconnect();
    }

    state.observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
        }
      });
    }, observerOptions);

    document.querySelectorAll('[data-aos]').forEach((el) => {
      el.classList.remove('animate-in');
      state.observer.observe(el);
    });

    if (!state.scrollHandler) {
      state.scrollHandler = () => {
        const scrolled = window.pageYOffset;
        const speed = 0.5;

        document.querySelectorAll('.floating-element').forEach((element) => {
          const yPos = -(scrolled * speed);
          element.style.transform = `translateY(${yPos}px)`;
        });
      };

      window.addEventListener('scroll', state.scrollHandler, { passive: true });
    }

    state.scrollHandler();
  }

  if (!window.__homeAnimationsBound) {
    document.addEventListener('astro:page-load', initializeAnimations);
    window.__homeAnimationsBound = true;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeAnimations, { once: true });
  } else {
    initializeAnimations();
  }
</script>

<style>
  /* Hero Section */
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    background: #ffffff;
    background: linear-gradient(0deg,rgba(255, 255, 255, 1) 0%, rgba(230, 230, 230, 1) 100%);
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    opacity: 0.1;
  }

  .floating-elements {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .floating-element {
    position: absolute;
    width: 60px;
    height: 60px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 50%;
    animation: float var(--duration) ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .floating-element:nth-child(1) { top: 20%; left: 10%; }
  .floating-element:nth-child(2) { top: 60%; right: 15%; }
  .floating-element:nth-child(3) { bottom: 30%; left: 20%; }
  .floating-element:nth-child(4) { top: 40%; right: 30%; }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(180deg); }
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* Hero Text */
  .hero-text {
    color: #333;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(10px);
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 0.9rem;
    margin-bottom: 30px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    color: #555;
  }

  .badge-icon {
    font-size: 1.2rem;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 30px;
    color: #2c3e50;
  }

  .title-line {
    display: block;
    opacity: 0;
    transform: translateY(30px);
    animation: slideInUp 0.8s ease forwards;
  }

  .title-line:nth-child(1) { animation-delay: 0.2s; }
  .title-line:nth-child(2) { animation-delay: 0.4s; }
  .title-line:nth-child(3) { animation-delay: 0.6s; }

  .highlight {
    background: linear-gradient(45deg, #d32f2f, #ff6b6b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @keyframes slideInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-description {
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: 40px;
    color: #555;
  }

  .hero-features {
    display: flex;
    gap: 30px;
    margin-bottom: 40px;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
    color: #666;
  }

  .feature-icon {
    font-size: 1.5rem;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hero Actions */
  .hero-actions {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .cta-button {
    position: relative;
    padding: 16px 32px;
    border: none;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    overflow: hidden;
  }

  .cta-button.primary {
    background: linear-gradient(45deg, #d32f2f, #ff6b6b);
    color: white;
    box-shadow: 0 10px 30px rgba(211, 47, 47, 0.3);
  }

  .cta-button.secondary {
    background: rgba(0, 0, 0, 0.05);
    color: #333;
    border: 2px solid rgba(0, 0, 0, 0.1);
    backdrop-filter: blur(10px);
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
  }

  .button-content {
    display: flex;
    align-items: center;
    gap: 10px;
    position: relative;
    z-index: 2;
  }

  .button-icon {
    width: 20px;
    height: 20px;
  }

  .button-glow {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s ease;
  }

  .cta-button:hover .button-glow {
    left: 100%;
  }

  /* Hero Visual */
  .hero-visual {
    position: relative;
  }

  .image-container {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }

  .image-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(from 0deg, #d32f2f, #ff6b6b, #48cae4, #d32f2f);
    animation: rotate 4s linear infinite;
    z-index: -1;
  }

  @keyframes rotate {
    100% { transform: rotate(360deg); }
  }

  .hero-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    position: relative;
    z-index: 1;
  }

  .image-overlay {
    position: absolute;
    top: 20px;
    right: 20px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .stats-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    padding: 15px 20px;
    border-radius: 15px;
    text-align: center;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }

  .stat-number {
    font-size: 1.8rem;
    font-weight: 800;
    color: #333;
    margin-bottom: 5px;
  }

  .stat-label {
    font-size: 0.8rem;
    color: #666;
    font-weight: 500;
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: #666;
    opacity: 0.8;
    animation: bounce 2s infinite;
  }

  .scroll-text {
    font-size: 0.9rem;
    margin-bottom: 10px;
  }

  .scroll-arrow {
    width: 24px;
    height: 24px;
    margin: 0 auto;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
  }

  /* Features Section - FIXED FOR MOBILE */
  .features-section {
    padding: 80px 0;
    background: white;
    overflow-x: hidden; /* Prevent horizontal scroll */
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 20px;
  }

  .section-subtitle {
    font-size: 1.2rem;
    color: #666;
    max-width: 600px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    width: 100%;
    justify-items: center; /* Center the grid items */
  }

  .feature-card {
    text-align: center;
    padding: 30px 20px;
    border-radius: 20px;
    background: white;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(30px);
    width: 100%;
    max-width: 350px; /* Limit max width */
  }

  .feature-card.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
  }

  .card-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 20px;
    background: linear-gradient(45deg, #d32f2f, #ff6b6b);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .feature-card h3 {
    font-size: 1.3rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 15px;
  }

  .feature-card p {
    color: #666;
    line-height: 1.6;
  }

  /* Animation classes */
  [data-aos] {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease;
  }

  [data-aos].animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  [data-aos="fade-right"] {
    transform: translateX(-30px);
  }

  [data-aos="fade-left"] {
    transform: translateX(30px);
  }

  [data-aos="zoom-in"] {
    transform: scale(0.8);
  }

  [data-aos="fade-right"].animate-in,
  [data-aos="fade-left"].animate-in,
  [data-aos="zoom-in"].animate-in {
    transform: translateX(0) scale(1);
  }

  /* Responsive Design - IMPROVED MOBILE SPACING */
  @media (max-width: 768px) {
    .hero-section {
      min-height: auto;
      padding: 36px 0 52px;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 28px;
      text-align: center;
    }

    .hero-badge {
      margin-bottom: 20px;
      font-size: 0.82rem;
      padding: 7px 12px;
      border-radius: 999px;
    }

    .hero-title {
      font-size: 2.2rem;
      margin-bottom: 18px;
    }

    .hero-description {
      font-size: 1.02rem;
      margin-bottom: 24px;
    }

    .hero-features {
      flex-direction: column;
      gap: 14px;
      margin-bottom: 24px;
      align-items: flex-start;
      text-align: left;
    }

    .feature-item {
      width: 100%;
      justify-content: flex-start;
      font-size: 0.95rem;
    }

    .hero-actions {
      justify-content: center;
      width: 100%;
    }

    .cta-button {
      width: 100%;
      justify-content: center;
      padding: 13px 22px;
      font-size: 1rem;
    }

    .hero-visual {
      width: 100%;
    }

    .image-container {
      border-radius: 16px;
    }

    .hero-image {
      height: 280px;
    }

    .scroll-indicator {
      bottom: 14px;
    }

    /* Features section mobile fixes */
    .features-section {
      padding: 48px 0;
    }

    .section-header {
      margin-bottom: 28px;
    }

    .section-title {
      font-size: 1.9rem;
      margin-bottom: 10px;
    }

    .section-subtitle {
      font-size: 0.98rem;
      line-height: 1.45;
    }

    .features-grid {
      grid-template-columns: 1fr;
      gap: 18px;
      max-width: 400px; /* Limit grid width on mobile */
      margin: 0 auto; /* Center the grid */
    }

    .feature-card {
      padding: 24px 18px;
      margin: 0; /* Remove problematic margin */
      max-width: 100%; /* Full width within grid */
      border-radius: 16px;
    }
  }

  @media (max-width: 480px) {
    .hero-section {
      padding: 30px 0 46px;
    }

    .hero-title {
      font-size: 1.88rem;
      line-height: 1.15;
    }

    .hero-description {
      font-size: 0.95rem;
      margin-bottom: 18px;
    }

    .hero-badge {
      font-size: 0.75rem;
      margin-bottom: 14px;
    }

    .feature-item {
      font-size: 0.9rem;
      gap: 8px;
    }

    .feature-icon {
      font-size: 1.2rem;
    }

    .cta-button {
      font-size: 0.92rem;
      padding: 12px 16px;
      border-radius: 14px;
    }

    .button-icon {
      width: 18px;
      height: 18px;
    }

    .image-container {
      border-radius: 14px;
    }

    .hero-image {
      height: 240px;
    }

    .section-title {
      font-size: 1.55rem;
    }

    .section-subtitle {
      font-size: 0.92rem;
    }

    .features-grid {
      gap: 14px;
      max-width: 100%; /* Full width on very small screens */
    }

    .feature-card {
      padding: 20px 16px;
    }

    .feature-card h3 {
      font-size: 1rem;
      margin-bottom: 10px;
    }

    .feature-card p {
      font-size: 0.86rem;
      line-height: 1.5;
    }
  }

  /* Extra small devices */
  @media (max-width: 320px) {
    .hero-title {
      font-size: 1.6rem;
    }

    .hero-image {
      height: 210px;
    }

    .features-grid {
      gap: 12px;
    }

    .feature-card {
      padding: 16px 12px;
    }
  }

  @media (max-width: 360px) {
    .hero-content {
      gap: 22px;
    }

    .hero-features {
      gap: 10px;
    }

    .features-section {
      padding: 40px 0;
    }
  }
</style>
